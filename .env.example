# Copy to .env and fill values. Never commit real secrets.
SESSION_SECRET=change_me_to_a_random_string
NODE_ENV=production
PORT=3000
DATABASE_URL=postgres://user:pass@host:5432/dbname
REDIS_URL=redis://localhost:6379
ALLOWED_ORIGINS=https://your-site.com,https://*.vercel.app
OWNER_PASSWORD_HASH=$2a$10$examplehash
SETUP_TOKEN=changeme

# Optional: Cloudflare R2 (for uploads)
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=

# CI / Deploy secrets (set in GitHub / Netlify settings)
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=# ============================================
# Environment Configuration
# ============================================
# Copy this file to .env and update values for your deployment

# ============================================
# Server Configuration
# ============================================
# Server port (default: 3000 for main server, 3001 for owner-railway)
PORT=3000
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# SQLite database file path (relative or absolute)
# Leave empty to use default location
DB_PATH=

# MongoDB connection string (optional, for production)
MONGODB_URI=mongodb+srv://srushti:<db_password>@cluster0.zvbuzce.mongodb.net/?appName=Cluster0

# Redis URL for session storage (optional, for production)
REDIS_URL=

# Gemini / OpenAI API Key for the AI cake designer
GEMINI_API_KEY=

# Optional: model name if you want to override the default
# GEMINI_MODEL=gpt-4.1-mini

# ============================================
# Cross-Deployment CORS Configuration
# ============================================
# For production, specify allowed origins for CORS
# Format: comma-separated list of URLs
# Example: https://your-vercel-domain.vercel.app,https://your-railway-domain.up.railway.app
ALLOWED_ORIGINS=https://crave-essa-discount-landing-production.up.railway.app,https://crave-essa-discount-landing.vercel.app

# ============================================
# Session Configuration
# ============================================
# Session secret key (change this in production!)
SESSION_SECRET=change_this_secret

# ============================================
# Owner Authentication (owner-railway)
# ============================================
# Note: Owner credentials are currently hardcoded in server.js
# Default: username=srushti, password=chetansrushti
# To change, update OWNER_USERNAME and OWNER_PASSWORD_HASH in owner-railway/server.js

# ============================================
# Client-Side Configuration (public/config.discount.js)
# ============================================
# For Vercel deployments, set this to the Railway owner server URL
# When deployed to Vercel, this environment variable can be set in Vercel dashboard
REACT_APP_API_URL="https://crave-essa-discount-landing-production.up.railway.app/owner"

# Alternative: Set window.__CRAVEESSA_API_URL__ in a separate config file or script
# This takes precedence over REACT_APP_API_URL
